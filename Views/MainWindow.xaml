<Window x:Class="WifiQrScanner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Title="WiFi QR Scanner &amp; Share"
        Width="900" Height="640"
        MinWidth="600" MinHeight="440"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F0F"
        ResizeMode="CanResize"
        Icon="/Assets/icon.ico"
        Closing="Window_Closing">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Small circular icon button (Segoe MDL2 Assets glyphs) -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#2E2E2E"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="Width"           Value="28"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="400"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"     Value="#1F2937"/>
                                <Setter TargetName="Root" Property="BorderBrush"    Value="#3B82F6"/>
                                <Setter Property="Foreground" Value="#F2F2F2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#111827"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BarePasswordBox" TargetType="PasswordBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#F2F2F2"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="CaretBrush"      Value="#F2F2F2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Background"      Value="#1F2937"/>
            <Setter Property="Foreground"      Value="#F2F2F2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#374151"/>
                            </Trigger>
                            <Trigger Property="IsPressed"    Value="True">
                                <Setter Property="Background" Value="#111827"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Camera Feed ───────────────────────────────────────── -->
        <Grid Grid.Row="0" Background="#050505">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Live frame -->
            <Image x:Name="CameraImage" Grid.Column="0"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="LowQuality"/>

            <!-- Scan guide brackets (idle only — shown via code-behind) -->
            <Border x:Name="ScanGuide" Grid.Column="0"
                    Width="200" Height="200"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsHitTestVisible="False">
                <Canvas>
                    <Rectangle Canvas.Left="0"   Canvas.Top="0"    Width="28" Height="3" Fill="White" Opacity="0.65"/>
                    <Rectangle Canvas.Left="0"   Canvas.Top="0"    Width="3"  Height="28" Fill="White" Opacity="0.65"/>
                    <Rectangle Canvas.Right="0"  Canvas.Top="0"    Width="28" Height="3" Fill="White" Opacity="0.65"/>
                    <Rectangle Canvas.Right="0"  Canvas.Top="0"    Width="3"  Height="28" Fill="White" Opacity="0.65"/>
                    <Rectangle Canvas.Left="0"   Canvas.Bottom="0" Width="28" Height="3" Fill="White" Opacity="0.65"/>
                    <Rectangle Canvas.Left="0"   Canvas.Bottom="0" Width="3"  Height="28" Fill="White" Opacity="0.65"/>
                    <Rectangle Canvas.Right="0"  Canvas.Bottom="0" Width="28" Height="3" Fill="White" Opacity="0.65"/>
                    <Rectangle Canvas.Right="0"  Canvas.Bottom="0" Width="3"  Height="28" Fill="White" Opacity="0.65"/>
                </Canvas>
            </Border>

            <!-- Camera loading overlay -->
            <Border x:Name="LoadingPanel" Grid.Column="0"
                    Background="#0F0F0F"
                    Visibility="Visible">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Spinning arc -->
                    <Grid Width="48" Height="48" HorizontalAlignment="Center">
                        <Ellipse Width="48" Height="48"
                                 Stroke="#222222" StrokeThickness="3"/>
                        <Ellipse x:Name="SpinnerArc"
                                 Width="48" Height="48"
                                 Stroke="#3B82F6" StrokeThickness="3"
                                 StrokeDashArray="20 60"
                                 StrokeDashCap="Round"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetName="SpinnerRotate"
                                                Storyboard.TargetProperty="Angle"
                                                From="0" To="360"
                                                Duration="0:0:1"
                                                RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Grid>
                    <TextBlock Text="Starting camera…"
                               FontFamily="Segoe UI" FontSize="13"
                               Foreground="#4B5563"
                               HorizontalAlignment="Center"
                               Margin="0,14,0,0"/>
                </StackPanel>
            </Border>

            <!-- No camera message -->
            <StackPanel x:Name="NoCameraPanel" Grid.Column="0"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="Collapsed">
                <TextBlock Text="⚠" FontSize="44" Foreground="#EF4444"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="NoCameraTitle"
                           Text="Camera unavailable"
                           FontSize="18" Foreground="#F2F2F2" FontFamily="Segoe UI"
                           Margin="0,12,0,0" HorizontalAlignment="Center"/>
                <TextBlock x:Name="NoCameraDetail"
                           Text="{Binding NoCameraDetailText}"
                           FontSize="13" Foreground="#6B7280" FontFamily="Segoe UI"
                           Margin="0,6,0,0" HorizontalAlignment="Center"
                           MaxWidth="400" TextWrapping="Wrap" TextAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <Button x:Name="OpenCameraSettingsBtn"
                            Content="Open Camera Settings"
                            Style="{StaticResource PillButton}"
                            Margin="0,0,8,0"
                            Click="OpenCameraSettings_Click"/>
                    <Button x:Name="RetryCameraBtn"
                            Content="Retry"
                            Style="{StaticResource PillButton}"
                            Margin="0,0,8,0"
                            Click="RetryCamera_Click"/>
                    <Button x:Name="CopyDiagnosticsBtn"
                            Content="Copy Diagnostics"
                            Style="{StaticResource PillButton}"
                            Click="CopyDiagnostics_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- Share panel -->
            <Border x:Name="SharePanel"
                    Grid.Column="1"
                    Width="220"
                    Background="#0A0A0A"
                    BorderBrush="#222222" BorderThickness="1,0,0,0"
                    Visibility="Collapsed">
                <StackPanel Margin="16,20,16,16">
                    <TextBlock Text="SHARE WIFI"
                               FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                               Foreground="#4B5563"
                               Margin="0,0,0,14"/>

                    <Border Background="#141414" CornerRadius="8" Padding="4">
                        <Image x:Name="ShareQrImage"
                               Width="180" Height="180"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </Border>

                    <TextBlock x:Name="ShareSsidText"
                               FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                               Foreground="#F2F2F2"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>

                    <TextBlock Text="PASSWORD"
                               FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                               Foreground="#4B5563"
                               Margin="0,14,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#141414" CornerRadius="6"
                                BorderBrush="#2E2E2E" BorderThickness="1">
                            <TextBox x:Name="SharePasswordBox"
                                     FontFamily="Segoe UI" FontSize="12"
                                     Foreground="#F2F2F2" Background="Transparent"
                                     BorderThickness="0" Padding="8,6"
                                     CaretBrush="#F2F2F2"
                                     IsReadOnly="True"
                                     TextChanged="SharePassword_Changed"/>
                        </Border>
                        <Button x:Name="ShareTogglePasswordBtn"
                                Grid.Column="1"
                                Content="&#xE7B3;"
                                Style="{StaticResource IconButton}"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Click="ShareTogglePassword_Click">
                            <Button.ToolTip>
                                <ToolTip Content="Show password" Background="#1F2937" Foreground="#F2F2F2"
                                         BorderBrush="#2E2E2E" FontFamily="Segoe UI" FontSize="12"/>
                            </Button.ToolTip>
                        </Button>
                        <Button x:Name="ShareCopyPasswordBtn"
                                Grid.Column="2"
                                Content="&#xE8C8;"
                                Style="{StaticResource IconButton}"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                Click="ShareCopyPassword_Click">
                            <Button.ToolTip>
                                <ToolTip Content="Copy password" Background="#1F2937" Foreground="#F2F2F2"
                                         BorderBrush="#2E2E2E" FontFamily="Segoe UI" FontSize="12"/>
                            </Button.ToolTip>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

        </Grid>

        <!-- ── Status Bar ────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="#141414"
                BorderBrush="#222222"
                BorderThickness="0,1,0,0"
                Height="96"
                Padding="24,16,24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">

                    <!-- Network info row (SSID + password badges) -->
                    <StackPanel x:Name="NetworkInfoRow"
                                Orientation="Horizontal"
                                Margin="0,0,0,8"
                                Visibility="Collapsed">

                        <!-- SSID badge -->
                        <Border Background="#1D3461" CornerRadius="5" Padding="10,5" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="SSID" FontSize="11" Foreground="#3B82F6"
                                           FontFamily="Segoe UI" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock x:Name="SsidText" FontSize="12" Foreground="#F2F2F2"
                                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Password badge -->
                        <Border x:Name="PasswordBadge"
                                Background="#1A2A1A" CornerRadius="5" Padding="10,5" Margin="0,0,8,0"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Password" FontSize="11" Foreground="#22C55E"
                                           FontFamily="Segoe UI" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock x:Name="PasswordText" FontSize="12" Foreground="#F2F2F2"
                                           FontFamily="Consolas" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Show/hide password toggle (eye icon) -->
                        <Button x:Name="TogglePasswordBtn"
                                Content="&#xE7B3;"
                                Style="{StaticResource IconButton}"
                                Visibility="Collapsed"
                                Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                Click="TogglePassword_Click">
                            <Button.ToolTip>
                                <ToolTip Content="Show password" Background="#1F2937" Foreground="#F2F2F2"
                                         BorderBrush="#2E2E2E" FontFamily="Segoe UI" FontSize="12"/>
                            </Button.ToolTip>
                        </Button>

                        <!-- Copy password button (copy icon) -->
                        <Button x:Name="CopyPasswordBtn"
                                Content="&#xE8C8;"
                                Style="{StaticResource IconButton}"
                                Visibility="Collapsed"
                                VerticalAlignment="Center"
                                Click="CopyPassword_Click">
                            <Button.ToolTip>
                                <ToolTip Content="Copy password" Background="#1F2937" Foreground="#F2F2F2"
                                         BorderBrush="#2E2E2E" FontFamily="Segoe UI" FontSize="12"/>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>

                    <!-- Status text -->
                    <TextBlock x:Name="StatusLabel"
                               Text="Point camera at a WiFi QR code"
                               FontFamily="Segoe UI" FontSize="14"
                               Foreground="#F2F2F2"/>

                    <!-- Progress bar -->
                    <ProgressBar x:Name="ConnectingBar"
                                 IsIndeterminate="True"
                                 Height="2" Margin="0,10,0,0"
                                 Foreground="#3B82F6"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Visibility="Collapsed"/>
                </StackPanel>

                <!-- Scan again button -->
                <Button x:Name="RetryButton"
                        Grid.Column="1"
                        Content="Scan Again"
                        Style="{StaticResource PillButton}"
                        VerticalAlignment="Center"
                        Visibility="Collapsed"
                        Click="RetryButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
